{
	"compilerOptions": {
		"composite": true,
		"target": "ES2020",
		"lib": ["ES2020"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": false,
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "esnext",
		"moduleResolution": "bundler"
	},
	"include": ["src/**/*"],
	"references": [
		{ "path": "../a" }
	]
}
